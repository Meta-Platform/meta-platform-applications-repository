{
    "params" : [
        "serverName",
        "RT_ENV_GENERATED_DIR_NAME",
        "installDataDirPath",
        "REPOS_CONF_FILENAME_REPOS_DATA",
        "REPOS_CONF_EXT_MODULE_DIR",
        "REPOS_CONF_EXT_LAYER_DIR",
        "REPOS_CONF_EXT_GROUP_DIR",
        "REPOS_CONF_EXTLIST_PKG_TYPE",
        "PKG_CONF_DIRNAME_METADATA",
        "EXECUTIONDATA_CONF_DIRNAME_DEPENDENCIES",
        "ECOSYSTEMDATA_CONF_FILENAME_PKG_GRAPH_DATA",
        "platformApplicationSocketPath"
    ],
    "windows": [
        {
            "title": "Instance Executor Control Panel",
            "width": 1280,
            "height": 800,
            "dependency": "@/instance-executor-control-panel.webgui",
            "params": {
                "serverName":                                 "{{serverName}}",
                "RT_ENV_GENERATED_DIR_NAME":                  "{{RT_ENV_GENERATED_DIR_NAME}}",
                "installDataDirPath":                         "{{installDataDirPath}}",
                "ECO_DIRPATH_INSTALL_DATA":                   "{{installDataDirPath}}",
                "REPOS_CONF_FILENAME_REPOS_DATA":             "{{REPOS_CONF_FILENAME_REPOS_DATA}}",
                "REPOS_CONF_EXT_MODULE_DIR":                  "{{REPOS_CONF_EXT_MODULE_DIR}}",
                "REPOS_CONF_EXT_LAYER_DIR":                   "{{REPOS_CONF_EXT_LAYER_DIR}}",
                "REPOS_CONF_EXT_GROUP_DIR":                   "{{REPOS_CONF_EXT_GROUP_DIR}}",
                "REPOS_CONF_EXTLIST_PKG_TYPE":                "{{REPOS_CONF_EXTLIST_PKG_TYPE}}",
                "PKG_CONF_DIRNAME_METADATA":                  "{{PKG_CONF_DIRNAME_METADATA}}",
                "EXECUTIONDATA_CONF_DIRNAME_DEPENDENCIES":    "{{EXECUTIONDATA_CONF_DIRNAME_DEPENDENCIES}}",
                "ECOSYSTEMDATA_CONF_FILENAME_PKG_GRAPH_DATA": "{{ECOSYSTEMDATA_CONF_FILENAME_PKG_GRAPH_DATA}}",
                "platformApplicationSocketPath":              "{{platformApplicationSocketPath}}"
            },
            "bound-params": {
                "instanceExecutorControlPanelWebgui":     "@/instance-executor-control-panel.webgui",
                "instanceExecutorControlPanelGuiService": "@/instance-executor-control-panel-gui.service",
                "instanceExecutorControlPanelWebservice": "@/instance-executor-control-panel.webservice",
                "commandLineRuntimeService":              "@/command-line-runtime.service",
                "instanceManagerRuntimeService":          "@/instance-manager-runtime.service",
                "instanceManagerClientLib":               "@/instance-manager-client.lib",
                "repositoryManagerService":               "@/repository-manager.service",
                "repositoryUtilitiesLib":                 "@/repository-utilities.lib",
                "dependencyGraphBuilderLib":              "@/dependency-graph-builder.lib"
            },
            "gui-host": {
                "webgui": "instanceExecutorControlPanelWebgui",
                "guiService": "guiService",
                "serviceGraph": [
                    {
                        "ref": "repositoryManager",
                        "package": "repositoryManagerService",
                        "factory": "Services/RepositoryManager.service",
                        "boundLibs": {
                            "repositoryUtilitiesLib": "repositoryUtilitiesLib",
                            "dependencyGraphBuilderLib": "dependencyGraphBuilderLib"
                        }
                    },
                    {
                        "ref": "commandLineRuntime",
                        "package": "commandLineRuntimeService",
                        "factory": "Services/CommandLineRuntime.service",
                        "boundLibs": {
                            "instanceManagerClientLib": "instanceManagerClientLib"
                        }
                    },
                    {
                        "ref": "instanceManagerRuntime",
                        "package": "instanceManagerRuntimeService",
                        "factory": "Services/InstanceManagerRuntime.service",
                        "boundLibs": {
                            "instanceManagerClientLib": "instanceManagerClientLib"
                        }
                    },
                    {
                        "ref": "guiService",
                        "package": "instanceExecutorControlPanelGuiService",
                        "factory": "Services/InstanceExecutorControlPanelGui.service",
                        "boundServices": {
                            "repositoryManagerService": "repositoryManager",
                            "commandLineRuntimeService": "commandLineRuntime",
                            "instanceManagerRuntimeService": "instanceManagerRuntime"
                        },
                        "boundLibs": {
                            "instanceExecutorControlPanelWebservice": "instanceExecutorControlPanelWebservice"
                        }
                    }
                ]
            }
        }
    ]
}
