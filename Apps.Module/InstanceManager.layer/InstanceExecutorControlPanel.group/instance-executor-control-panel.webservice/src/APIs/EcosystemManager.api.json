{
	"name": "EcosystemManager",
	"endpoints": [
		{
			"summary": "ListPackages",
			"method": "GET",
			"path": "/list-packages"
		},
		{
			"summary": "PackageList",
			"method": "WS",
			"path": "/package-list"
		},
		{
			"summary": "RunPackage",
			"method": "POST",
			"path": "/run-package",
			"parameters": [
				{
					"name": "namespaceRepo",
					"in": "body",
					"type": "string",
					"required": true
				},
				{
					"name": "moduleName",
					"in": "body",
					"type": "string",
					"required": true
				},
				{
					"name": "layerName",
					"in": "body",
					"type": "string",
					"required": true
				},
				{
					"name": "packageName",
					"in": "body",
					"type": "string",
					"required": true
				},
				{
					"name": "ext",
					"in": "body",
					"type": "string",
					"required": true
				},
				{
					"name": "parentGroup",
					"in": "body",
					"type": "string",
					"required": false
				},
				{
					"name": "startupParams",
					"in": "body",
					"type": "json",
					"required": false
				},
				{
					"name": "launchedBy",
					"in": "body",
					"type": "string",
					"required": false
				}
			]
		},
		{
			"summary": "StopPackage",
			"method": "POST",
			"path": "/stop-package",
			"parameters": [
				{ "name": "namespaceRepo", "in": "body", "type": "string", "required": false },
				{ "name": "moduleName", "in": "body", "type": "string", "required": false },
				{ "name": "layerName", "in": "body", "type": "string", "required": false },
				{ "name": "packageName", "in": "body", "type": "string", "required": false },
				{ "name": "ext", "in": "body", "type": "string", "required": false },
				{ "name": "parentGroup", "in": "body", "type": "string", "required": false },
				{ "name": "packagePath", "in": "body", "type": "string", "required": false }
			]
		},
		{
			"summary": "StopInstance",
			"method": "POST",
			"path": "/stop-instance",
			"parameters": [
				{ "name": "instanceId", "in": "body", "type": "string", "required": true }
			]
		}
	]
}