{
  "name": "TaskExecutorMonitor",
  "endpoints": [
    {
      "summary": "GetMonitoringState",
      "method": "GET",
      "path": "/monitoring/state"
    },
    {
      "summary": "MonitoringState",
      "method": "WS",
      "path": "/monitoring"
    },
    {
      "summary": "ListInstances",
      "method": "GET",
      "path": "/list-instances"
    },
    {
      "summary": "InstanceList",
      "method": "WS",
      "path": "/instance-list"
    },
    {
      "summary": "ListTasks",
      "method": "GET",
      "path": "/list-task"
    },
    {
      "summary": "TaskList",
      "method": "WS",
      "path": "/task-list"
    },
    {
      "summary": "GetTaskTreeById",
      "method": "POST",
      "path": "/task-tree-by-id",
      "parameters": [
				{
					"name": "taskId",
					"in": "body",
					"type": "string",
					"required": true
				}
      ]
    },
    {
      "summary": "GetTaskInformation",
      "method": "POST",
      "path": "/task/information",
      "parameters": [
				{
					"name": "taskId",
					"in": "body",
					"type": "string",
					"required": true
				}
      ]
    },
    {
      "summary": "StopTasks",
      "method": "POST",
      "path": "/stop-tasks",
      "parameters": [
				{
					"name": "taskIds",
					"in": "body",
					"type": "json",
					"required": true
				}
      ]
    },
    {
      "summary": "ListInstanceTasks",
      "method": "POST",
      "path": "/instance-tasks",
      "parameters": [
				{
					"name": "instanceId",
					"in": "body",
					"type": "string",
					"required": true
				}
      ]
    },
    {
      "summary": "InstanceTaskStream",
      "method": "WS",
      "path": "/instance-task-stream/:instanceId",
      "parameters": [
				{
					"name": "instanceId",
					"in": "path",
					"type": "string",
					"required": true
				}
      ]
    },
    {
      "summary": "StopInstanceTasks",
      "method": "POST",
      "path": "/stop-instance-tasks",
      "parameters": [
				{
					"name": "instanceId",
					"in": "body",
					"type": "string",
					"required": true
				},
				{
					"name": "taskIds",
					"in": "body",
					"type": "json",
					"required": true
				}
      ]
    }
  ]
}