{
    "params": ["apisDirPath"],
    "bound-params":["serverService", "apiAuthoringLib"],
    "endpoints": [
        {
            "url": "/api-designer",
            "type": "controller",
            "params": {
                "api-template": "APIs/APIDesigner.api.json",
                "controller": "Controllers/APIDesigner.controller",
                "controller-params": {
                    "apisDir": "{{apisDirPath}}"
                }
            },
            "bound-params": {
                "serverService":"serverService",
                "controller-params": {
                    "apiAuthoringLib": "apiAuthoringLib"
                }
            }
        }
    ]
}