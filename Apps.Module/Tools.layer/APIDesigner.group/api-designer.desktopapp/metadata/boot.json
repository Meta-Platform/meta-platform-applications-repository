{
    "params" : [
        "apisDirPath",
        "serverName",
        "RT_ENV_GENERATED_DIR_NAME"
    ],
    "windows": [
        {
            "title": "API Designer",
            "width": 1280,
            "height": 800,
            "dependency": "@/api-designer.webgui",
            "params": {
                "serverName": "{{serverName}}",
                "RT_ENV_GENERATED_DIR_NAME": "{{RT_ENV_GENERATED_DIR_NAME}}",
                "apisDir": "{{apisDirPath}}"
            },
            "bound-params": {
                "apiDesignerWebgui":     "@/api-designer.webgui",
                "apiDesignerGuiService": "@/api-designer-gui.service",
                "apiDesignerWebservice": "@/api-designer.webservice",
                "apiAuthoringLib":       "@/api-authoring.lib"
            },
            "gui-host": {
                "webgui": "apiDesignerWebgui",
                "guiService": "guiService",
                "serviceGraph": [
                    {
                        "ref": "guiService",
                        "package": "apiDesignerGuiService",
                        "factory": "Services/ApiDesignerGui.service",
                        "boundLibs": {
                            "apiAuthoringLib":       "apiAuthoringLib",
                            "apiDesignerWebservice": "apiDesignerWebservice"
                        }
                    }
                ]
            }
        }
    ]
}
