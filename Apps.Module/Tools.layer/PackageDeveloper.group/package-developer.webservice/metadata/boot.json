{
    "params" : [
        "port",
        "serverName",
        "workspaceStorageFilePath",
        "runCommandPath"
    ],
    "services": [
        {
            "namespace": "@@/server-service",
            "dependency": "@/server-manager.service/services/HTTPServerService",
            "params":{
                "name":"{{serverName}}",
                "port": "{{port}}"
            }
        },
        {
            "namespace": "@@/package-handler-service",
            "dependency": "@/package-developer.lib/services/PackageHandlerManager",
            "params": {
                "workspaceStorageFilePath": "{{workspaceStorageFilePath}}"
            },
            "bound-params": {
                "workspaceStoreLib": "@/workspace-store.lib"
            }
        },
        {
            "namespace": "@@/package-process-service",
            "dependency": "@/package-process-manager.lib/services/ProcessManager",
            "params": {
                "runCommandPath": "{{runCommandPath}}"
            }
        },
        {
            "namespace": "@@/git-status-service",
            "dependency": "@/git-status.lib/services/GitStatusManager",
            "params": {}
        }
    ],
    "endpoints": [
        {
            "dependency": "@/server-manager.webservice/endpoint-group",
            "bound-params":{
               "serverServiceForController":"@@/server-service",
               "serverService": "@@/server-service"
            }
        },
        {
            "dependency": "@//endpoint-group",
            "bound-params":{
                "serverService": "@@/server-service",
                "packageHandlerManagerService": "@@/package-handler-service",
                "packageDeveloperLib":"@/package-developer.lib",
                "packageToolkitLib":"@/package-toolkit.lib",
                "processManagerService":"@@/package-process-service",
                "gitStatusManagerService":"@@/git-status-service"
            }
        }
    ]
}