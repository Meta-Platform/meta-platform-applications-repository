{
  "name": "ModuleDeveloper",
  "endpoints": [
    {
      "path": "/workspaces",
      "method": "GET",
      "summary": "ListWorkspaces"
    },
    {
      "path": "/recent-repositories",
      "method": "GET",
      "summary": "ListRecentRepositories"
    },
    {
      "path": "/workspace/:workspace/hierarchy",
      "method": "GET",
      "summary": "GetRepositoryHierarchy",
      "parameters": [
        { "name": "workspace", "in": "path", "type": "string", "required": true }
      ]
    },
    {
      "path": "/app-state/:key",
      "method": "GET",
      "summary": "GetAppState",
      "parameters": [
        { "name": "key", "in": "path", "type": "string", "required": true }
      ]
    },
    {
      "path": "/app-state",
      "method": "POST",
      "summary": "SetAppState",
      "parameters": [
        { "name": "key", "in": "body", "type": "string", "required": true },
        { "name": "value", "in": "body", "type": "string", "required": false }
      ]
    },
    {
      "path": "/workspace/:workspace/package",
      "method": "GET",
      "summary": "ListPackagesByWorkspace",
      "parameters": [
        {
          "name": "workspace",
          "in": "path",
          "type": "string",
          "required": true
        }
      ]
    },
    {
      "summary": "CreateWorkspace",
      "method": "POST",
      "path": "/workspace",
      "parameters": [
        {
          "name": "name",
          "in": "body",
          "type": "string",
          "required": true
        },
        {
          "name": "path",
          "in": "body",
          "type": "string",
          "required": true
        }
      ]
    },
    {
      "summary": "RemoveWorkspace",
      "method": "DELETE",
      "path": "/workspace/:name",
      "parameters": [
        {
          "name": "name",
          "in": "path",
          "type": "string",
          "required": true
        }
      ]
    },
    {
      "summary": "CreateRepository",
      "method": "POST",
      "path": "/repository",
      "parameters": [
        { "name": "name", "in": "body", "type": "string", "required": true },
        { "name": "path", "in": "body", "type": "string", "required": true }
      ]
    },
    {
      "summary": "BrowseDir",
      "method": "POST",
      "path": "/browse-dir",
      "parameters": [
        {
          "name": "path",
          "in": "body",
          "type": "string",
          "required": false
        }
      ]
    },
    {
      "summary": "CreateContainer",
      "method": "POST",
      "path": "/container",
      "parameters": [
        { "name": "workspace", "in": "body", "type": "string", "required": true },
        { "name": "parentPath", "in": "body", "type": "string", "required": false },
        { "name": "name", "in": "body", "type": "string", "required": true },
        { "name": "kind", "in": "body", "type": "string", "required": true }
      ]
    },
    {
      "summary": "CreatePackage",
      "method": "POST",
      "path": "/package",
      "parameters": [
        { "name": "workspace", "in": "body", "type": "string", "required": true },
        { "name": "targetPath", "in": "body", "type": "string", "required": false },
        { "name": "packageName", "in": "body", "type": "string", "required": true },
        { "name": "ext", "in": "body", "type": "string", "required": true }
      ]
    },
    {
      "summary": "RenameNode",
      "method": "POST",
      "path": "/rename-node",
      "parameters": [
        { "name": "workspace", "in": "body", "type": "string", "required": true },
        { "name": "path", "in": "body", "type": "string", "required": true },
        { "name": "newName", "in": "body", "type": "string", "required": true }
      ]
    },
    {
      "summary": "DeleteNode",
      "method": "POST",
      "path": "/delete-node",
      "parameters": [
        { "name": "workspace", "in": "body", "type": "string", "required": true },
        { "name": "path", "in": "body", "type": "string", "required": true }
      ]
    },
    {
      "summary": "Status",
      "method": "GET",
      "path": "/status"
    },
    {
      "summary": "GitStatusStream",
      "method": "WS",
      "path": "/git-status",
      "parameters": [
        { "name": "repositories", "in": "query", "type": "string", "required": false }
      ]
    },
    {
      "summary": "GetIcon",
      "method": "GET",
      "path": "/icon/:workspace/:packageName/:ext",
      "typeResponse" : "file",
      "parameters": [
        {
          "name": "workspace",
          "in": "path",
          "type": "string",
          "required": true
        },
        {
          "name": "packageName",
          "in": "path",
          "type": "string",
          "required": true
        },
        {
          "name": "ext",
          "in": "path",
          "type": "string",
          "required": true
        }
      ]
    }
  ]
}