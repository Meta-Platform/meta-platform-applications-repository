{
    "params" : [
        "serverName",
        "RT_ENV_GENERATED_DIR_NAME",
        "workspaceStorageFilePath",
        "runCommandPath"
    ],
    "windows": [
        {
            "title": "Package Developer",
            "width": 1280,
            "height": 800,
            "dependency": "@/package-developer.webgui",
            "params": {
                "serverName":               "{{serverName}}",
                "RT_ENV_GENERATED_DIR_NAME": "{{RT_ENV_GENERATED_DIR_NAME}}",
                "workspaceStorageFilePath": "{{workspaceStorageFilePath}}",
                "runCommandPath":           "{{runCommandPath}}"
            },
            "bound-params": {
                "packageDeveloperWebgui":     "@/package-developer.webgui",
                "packageDeveloperGuiService": "@/package-developer-gui.service",
                "packageDeveloperWebservice": "@/package-developer.webservice",
                "packageDeveloperLib":        "@/package-developer.lib",
                "packageProcessManagerLib":   "@/package-process-manager.lib",
                "packageToolkitLib":          "@/package-toolkit.lib",
                "workspaceStoreLib":          "@/workspace-store.lib"
            },
            "gui-host": {
                "webgui": "packageDeveloperWebgui",
                "guiService": "guiService",
                "serviceGraph": [
                    {
                        "ref": "packageHandlerManager",
                        "package": "packageDeveloperLib",
                        "factory": "Managers/PackageHandler",
                        "boundLibs": {
                            "workspaceStoreLib": "workspaceStoreLib"
                        }
                    },
                    {
                        "ref": "processManager",
                        "package": "packageProcessManagerLib",
                        "factory": "Services/ProcessManager.service"
                    },
                    {
                        "ref": "guiService",
                        "package": "packageDeveloperGuiService",
                        "factory": "Services/PackageDeveloperGui.service",
                        "boundServices": {
                            "packageHandlerManagerService": "packageHandlerManager",
                            "processManagerService": "processManager"
                        },
                        "boundLibs": {
                            "packageDeveloperLib": "packageDeveloperLib",
                            "packageToolkitLib": "packageToolkitLib",
                            "packageDeveloperWebservice": "packageDeveloperWebservice"
                        }
                    }
                ]
            }
        }
    ]
}
