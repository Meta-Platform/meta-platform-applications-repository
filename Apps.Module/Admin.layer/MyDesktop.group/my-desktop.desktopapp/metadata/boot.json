{
    "params": [
        "serverName",
        "installDataDirPath",
        "panelStateFilePath",
        "ecosystemDefaultsFileRelativePath",
        "platformApplicationSocketPath"
    ],
    "windows": [
        {
            "title": "MyDesktop",
            "width": 1280,
            "height": 800,
            "dependency": "@/home-screen.webgui",
            "params": {
                "serverName": "{{serverName}}",
                "installDataDirPath": "{{installDataDirPath}}",
                "panelStateFilePath": "{{panelStateFilePath}}",
                "ecosystemDefaultsFileRelativePath": "{{ecosystemDefaultsFileRelativePath}}",
                "platformApplicationSocketPath": "{{platformApplicationSocketPath}}"
            },
            "bound-params": {
                "homeScreenWebgui": "@/home-screen.webgui",
                "desktopGuiService": "@/desktop-gui.service",
                "executionManagerWebservice": "@/execution-manager.webservice",
                "repositoryManagerService": "@/repository-manager.service",
                "ecosystemControlPanelService": "@/ecosystem-control-panel.service",
                "jsonFileUtilitiesLib": "@/json-file-utilities.lib",
                "ecosystemDefaultsHandlerLib": "@/ecosystem-defaults-handler.lib",
                "ecosystemInstallUtilitiesLib": "@/ecosystem-install-utilities.lib",
                "repositoryUtilitiesLib": "@/repository-utilities.lib",
                "dependencyGraphBuilderLib": "@/dependency-graph-builder.lib",
                "instanceManagerClientLib": "@/instance-manager-client.lib"
            },
            "gui-host": {
                "webgui": "homeScreenWebgui",
                "guiService": "guiService",
                "serviceGraph": [
                    {
                        "ref": "notificationHub",
                        "package": "ecosystemControlPanelService",
                        "factory": "Services/NotificationHub.service"
                    },
                    {
                        "ref": "ecosystemData",
                        "package": "ecosystemControlPanelService",
                        "factory": "Services/EcosystemDataHandler.service",
                        "boundLibs": {
                            "ecosystemDefaultsHandlerLib": "ecosystemDefaultsHandlerLib"
                        }
                    },
                    {
                        "ref": "repositoryManager",
                        "package": "repositoryManagerService",
                        "factory": "Services/RepositoryManager.service",
                        "boundLibs": {
                            "repositoryUtilitiesLib": "repositoryUtilitiesLib",
                            "dependencyGraphBuilderLib": "dependencyGraphBuilderLib"
                        }
                    },
                    {
                        "ref": "guiService",
                        "package": "desktopGuiService",
                        "factory": "Services/DesktopGui.service",
                        "boundServices": {
                            "ecosystemdataHandlerService": "ecosystemData",
                            "notificationHubService": "notificationHub",
                            "repositoryManagerService": "repositoryManager"
                        },
                        "boundLibs": {
                            "jsonFileUtilitiesLib": "jsonFileUtilitiesLib",
                            "ecosystemInstallUtilitiesLib": "ecosystemInstallUtilitiesLib",
                            "executionManagerWebservice": "executionManagerWebservice",
                            "instanceManagerClientLib": "instanceManagerClientLib"
                        }
                    }
                ]
            }
        }
    ]
}
