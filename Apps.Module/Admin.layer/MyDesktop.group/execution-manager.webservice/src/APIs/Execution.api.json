{
	"name": "Execution",
	"endpoints": [
		{
			"summary": "RunApplication",
			"method": "POST",
			"path": "/run-application",
			"parameters": [
				{ "name": "namespaceRepo", "in": "body", "type": "string", "required": true },
				{ "name": "moduleName",    "in": "body", "type": "string", "required": true },
				{ "name": "layerName",     "in": "body", "type": "string", "required": true },
				{ "name": "packageName",   "in": "body", "type": "string", "required": true },
				{ "name": "ext",           "in": "body", "type": "string", "required": true },
				{ "name": "parentGroup",   "in": "body", "type": "string", "required": false },
				{ "name": "executableName","in": "body", "type": "string", "required": false }
			]
		},
		{
			"summary": "ListRunning",
			"method": "GET",
			"path": "/running"
		},
		{
			"summary": "StopApplication",
			"method": "POST",
			"path": "/stop",
			"parameters": [
				{ "name": "executableName", "in": "body", "type": "string", "required": true }
			]
		},
		{
			"summary": "BuildProgressStream",
			"method": "WS",
			"path": "/build-progress"
		}
	]
}
