{
	"name": "DataSources",
	"endpoints": [
		{
			"path": "/data-source/fs",
			"method": "POST",
			"summary": "CreateFileSystem",
			"parameters": [
				{
					"name": "name",
					"in": "body",
					"type": "string",
					"required": true
				}
			]
		},
		{
			"path": "/data-source/datastore",
			"method": "POST",
			"summary": "CreateDataStore",
			"parameters": [
				{
					"name": "name",
					"in": "body",
					"type": "string",
					"required": true
				}
			]
		},
		{
			"path": "/data-source/orm",
			"method": "POST",
			"summary": "CreateORM",
			"parameters": [
				{ "in": "body", "name": "name",     "type": "string", "required": true },
				{ "in": "body", "name": "dialect",  "type": "string", "required": true },
				{ "in": "body", "name": "storage",  "type": "string", "required": false },
				{ "in": "body", "name": "host",     "type": "string", "required": false },
				{ "in": "body", "name": "port",     "type": "number", "required": false },
				{ "in": "body", "name": "database", "type": "string", "required": false },
				{ "in": "body", "name": "username", "type": "string", "required": false },
				{ "in": "body", "name": "password", "type": "string", "required": false }
			]
		},
		{
			"path": "/data-source",
			"method": "DELETE",
			"summary": "RemoveSource",
			"parameters": [
				{ "in": "body", "name": "keystone", "type": "string", "required": true }
			]
		},
		{
			"path": "/data-source",
			"method": "POST",
			"summary": "GetDataSource",
			"parameters": [
				{
					"name": "name",
					"in": "body",
					"type": "string",
					"required": true
				}
			]
		},
		{
			"summary": "Status",
			"method": "GET",
			"path": "/status"
		},
		{
			"summary": "ListDataSources",
			"method": "GET",
			"path": "/datasource-manager"
		},
		{
			"summary": "ListDataSourcesByType",
			"method": "GET",
			"path": "/datasource-manager/:type",
			"parameters": [
				{
					"name": "type",
					"in": "path",
					"type": "string",
					"required": true
				}
			]
		}
	]
}