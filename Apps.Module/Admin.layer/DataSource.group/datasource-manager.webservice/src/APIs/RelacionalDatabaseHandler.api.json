{
	"name": "RelacionalDatabaseHandler",
	"endpoints": [
		{
			"summary": "ShowAllTableName",
			"method": "GET",
			"path": "/show-all-table-name",
			"parameters": [
				{ "name": "keystone", "in": "query", "type": "string", "required": true },
				{ "name": "options",  "in": "query", "type": "json",   "required": false }
			]
		},
		{
			"summary": "DescribeTable",
			"method": "GET",
			"path": "/describe-table",
			"parameters": [
				{ "name": "keystone",  "in": "query", "type": "string", "required": true },
				{ "name": "tableName", "in": "query", "type": "string", "required": true }
			]
		},
		{
			"summary": "ShowTableIndexes",
			"method": "GET",
			"path": "/show-table-indexes",
			"parameters": [
				{ "name": "keystone",  "in": "query", "type": "string", "required": true },
				{ "name": "tableName", "in": "query", "type": "string", "required": true }
			]
		},
		{
			"summary": "CountRows",
			"method": "GET",
			"path": "/count-rows",
			"parameters": [
				{ "name": "keystone",  "in": "query", "type": "string", "required": true },
				{ "name": "tableName", "in": "query", "type": "string", "required": true }
			]
		},
		{
			"summary": "SelectRows",
			"method": "GET",
			"path": "/select-rows",
			"parameters": [
				{ "name": "keystone",  "in": "query", "type": "string", "required": true },
				{ "name": "tableName", "in": "query", "type": "string", "required": true },
				{ "name": "limit",     "in": "query", "type": "number", "required": false },
				{ "name": "offset",    "in": "query", "type": "number", "required": false },
				{ "name": "orderBy",   "in": "query", "type": "string", "required": false },
				{ "name": "orderDir",  "in": "query", "type": "string", "required": false }
			]
		},
		{
			"summary": "RunSQL",
			"method": "POST",
			"path": "/run-sql",
			"parameters": [
				{ "name": "keystone", "in": "body", "type": "string", "required": true },
				{ "name": "sql",      "in": "body", "type": "string", "required": true }
			]
		},
		{
			"summary": "InsertRow",
			"method": "POST",
			"path": "/insert-row",
			"parameters": [
				{ "name": "keystone",  "in": "body", "type": "string", "required": true },
				{ "name": "tableName", "in": "body", "type": "string", "required": true },
				{ "name": "values",    "in": "body", "type": "json",   "required": true }
			]
		},
		{
			"summary": "UpdateRow",
			"method": "PUT",
			"path": "/update-row",
			"parameters": [
				{ "name": "keystone",  "in": "body", "type": "string", "required": true },
				{ "name": "tableName", "in": "body", "type": "string", "required": true },
				{ "name": "values",    "in": "body", "type": "json",   "required": true },
				{ "name": "where",     "in": "body", "type": "json",   "required": true }
			]
		},
		{
			"summary": "DeleteRow",
			"method": "DELETE",
			"path": "/delete-row",
			"parameters": [
				{ "name": "keystone",  "in": "body", "type": "string", "required": true },
				{ "name": "tableName", "in": "body", "type": "string", "required": true },
				{ "name": "where",     "in": "body", "type": "json",   "required": true }
			]
		},
		{
			"summary": "CreateTable",
			"method": "POST",
			"path": "/create-table",
			"parameters": [
				{ "name": "keystone",  "in": "body", "type": "string", "required": true },
				{ "name": "tableName", "in": "body", "type": "string", "required": true },
				{ "name": "columns",   "in": "body", "type": "json",   "required": true }
			]
		},
		{
			"summary": "DropTable",
			"method": "DELETE",
			"path": "/drop-table",
			"parameters": [
				{ "name": "keystone",  "in": "body", "type": "string", "required": true },
				{ "name": "tableName", "in": "body", "type": "string", "required": true }
			]
		},
		{
			"summary": "AddColumn",
			"method": "POST",
			"path": "/add-column",
			"parameters": [
				{ "name": "keystone",  "in": "body", "type": "string", "required": true },
				{ "name": "tableName", "in": "body", "type": "string", "required": true },
				{ "name": "column",    "in": "body", "type": "json",   "required": true }
			]
		},
		{
			"summary": "RemoveColumn",
			"method": "DELETE",
			"path": "/remove-column",
			"parameters": [
				{ "name": "keystone",   "in": "body", "type": "string", "required": true },
				{ "name": "tableName",  "in": "body", "type": "string", "required": true },
				{ "name": "columnName", "in": "body", "type": "string", "required": true }
			]
		}
	]
}
