{
    "params": [
        "serverName",
        "appDataDir"
    ],
    "windows": [
        {
            "title": "Data Source Manager",
            "width": 1280,
            "height": 800,
            "dependency": "@/datasource-manager.webgui",
            "params": {
                "serverName": "{{serverName}}",
                "appDataDir": "{{appDataDir}}"
            },
            "bound-params": {
                "datasourceWebgui": "@/datasource-manager.webgui",
                "datasourceGuiService": "@/datasource-gui.service",
                "datasourceManagerWebservice": "@/datasource-manager.webservice",
                "datasourceManagerService": "@/datasource-manager.service"
            },
            "gui-host": {
                "webgui": "datasourceWebgui",
                "guiService": "guiService",
                "serviceGraph": [
                    {
                        "ref": "dataSourceLocal",
                        "package": "datasourceManagerService",
                        "factory": "Managers/DataSourceLocal"
                    },
                    {
                        "ref": "guiService",
                        "package": "datasourceGuiService",
                        "factory": "Services/DatasourceGui.service",
                        "boundServices": {
                            "dataSourceLocalService": "dataSourceLocal"
                        },
                        "boundLibs": {
                            "datasourceManagerWebservice": "datasourceManagerWebservice"
                        }
                    }
                ]
            }
        }
    ]
}
